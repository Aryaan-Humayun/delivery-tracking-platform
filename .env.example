# Copy this file to .env and adjust if needed. Defaults match docker-compose.yml.

NODE_ENV=development
PORT=3000

# PostgreSQL
# Local dev (docker-compose) uses host/port. In production (e.g. Railway with
# Neon), set DATABASE_URL instead (postgres://user:password@host:port/db) -
# it takes precedence over PGHOST/etc when set, and SSL is enabled
# automatically for it. See src/config/env.js.
PGHOST=localhost
PGPORT=5432
PGDATABASE=delivery_tracking
PGUSER=postgres
PGPASSWORD=postgres
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Redis
# Local dev (docker-compose) uses host/port. In production (e.g. Railway),
# set REDIS_URL instead (redis://[:password@]host:port) - it takes
# precedence over REDIS_HOST/REDIS_PORT when set. See src/config/env.js.
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_URL=redis://default:password@host:6379

# Auth
# Generate a real secret with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=24h
BCRYPT_SALT_ROUNDS=10

# Rate limiting (loosen these for your own local testing if they get in the way)
# General limiter applies to every route; the auth limiter additionally
# applies on top of it, just to POST /auth/register and /auth/login.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=5
